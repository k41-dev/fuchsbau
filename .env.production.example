# Copy to .env.production and fill in before: docker compose -f docker-compose.prod.yml --env-file .env.production up -d

# Public URL of the app (must match how users reach it in the browser)
ORIGIN=https://fuchsbau.example.com
BETTER_AUTH_URL=https://fuchsbau.example.com

# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=replace-with-a-long-random-secret

# Database (used by docker-compose.prod.yml)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace-with-a-strong-db-password
POSTGRES_DB=fuchsbau

# Host port to expose the app on
APP_PORT=3000