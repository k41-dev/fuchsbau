DATABASE_URL="postgresql://postgres:postgres@localhost:5432/fuchsbau"
BETTER_AUTH_SECRET="your-super-secret-key-change-this-min-32-chars"
BETTER_AUTH_URL="http://localhost:5173"

# Max upload size for form actions (project cover images are up to 5 MB)
BODY_SIZE_LIMIT=6M

